<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - NexStock</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>

<body>

    <header>
        <nav class="navbar navbar-expand-sm navbar-dark navbar-custom fixed-top">
            <div class="container-fluid">

                <!-- LOGO -->
                <a class="navbar-brand d-flex align-items-center">

                    <img src="~/img/logo.png" alt="Logo" class="logo-navbar" />

                    <span>NexStock</span>

                </a>

                <!-- 🔥 USUÁRIO + SAIR -->
                <div class="user-navbar">
                    <span>Usuário: @Context.Session.GetString("UserEmail")</span>

                    <a asp-controller="Usuario" asp-action="Logout" class="logout">
                        Sair
                    </a>
                </div>

            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="footer">
        © 2026 - NexStock | Sistema de Controle de Estoque
    </footer>

    <!-- Scripts -->
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js"></script>
    @RenderSection("Scripts", required: false)

    <!-- 🔥 LOADING (AGORA CORRETO) -->
    <div id="loading-screen">
        <div class="loading-spinner">
            <span></span>
            <span></span>
            <span></span>
            <span></span>
        </div>
    </div>

</body>
</html>